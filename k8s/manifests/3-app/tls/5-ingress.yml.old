apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: fiap-ingress
  namespace: fiap-soat11
  annotations:
    nginx.ingress.kubernetes.io/rewrite-target: /
spec:
  rules:
    - host: fiap-soat11.api.com
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: fiap-svc
                port:
                  number: 5002

---

apiVersion: v1
kind: Service
metadata:
  name: ingress-nginx-lb
  namespace: ingress-nginx
spec:
  type: LoadBalancer
  selector:
    app.kubernetes.io/component: controller
  ports:
    - name: http
      port: 80
      targetPort: 80